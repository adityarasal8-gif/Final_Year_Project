rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user is the owner
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Users collection
    match /users/{userId} {
      // Allow users to read their own profile
      allow read: if isOwner(userId);
      
      // Allow users to create/update their own profile without restrictions
      allow create: if isOwner(userId);
      allow write: if isOwner(userId);
      
      // Allow therapists to read their patients' profiles
      allow read: if isAuthenticated() && 
                     resource.data.therapistId == request.auth.uid;
      
      // Allow authenticated users to read specific fields for validation
      // (needed for therapist code validation and patient linking)
      allow read: if isAuthenticated();
      
      // Allow list queries for authenticated users (with limit)
      allow list: if isAuthenticated() && 
                     request.query.limit <= 100;
    }
    
    // Sessions collection
    match /sessions/{sessionId} {
      // Allow users to read/write their own sessions
      allow read, write: if isAuthenticated() && 
                            request.resource.data.userId == request.auth.uid;
      
      allow read: if isAuthenticated() && 
                     resource.data.userId == request.auth.uid;
      
      // Allow therapists to read sessions of their patients
      allow read: if isAuthenticated() && 
                     exists(/databases/$(database)/documents/users/$(resource.data.userId)) &&
                     get(/databases/$(database)/documents/users/$(resource.data.userId)).data.therapistId == request.auth.uid;
      
      // Allow list queries for authenticated users (with limit)
      allow list: if isAuthenticated() && 
                     request.query.limit <= 100;
    }
  }
}
